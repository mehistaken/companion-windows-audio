<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>AudioSidecar</AssemblyName>
    <RootNamespace>AudioSidecar</RootNamespace>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <!-- NAudio.Wasapi only — avoids pulling in NAudio.WinForms and its WPF/WinForms dependency chain -->
    <PackageReference Include="NAudio.Wasapi" Version="2.2.1" />
    <!-- Worker Service + Windows Service lifetime support -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="8.0.1" />
  </ItemGroup>

</Project>
